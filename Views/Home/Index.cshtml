@{
    ViewData["Title"] = "Invexa - Smart Inventory & Billing Platform";
}

<section class="landing-main">
    <div class="landing-wrap">
        <div class="landing-card">
            <h1>Invexa</h1>
            <p style="font-size: 1.3rem; color: var(--muted); margin-bottom: 0.5rem;">Smart Inventory & Billing Platform</p>
            <p style="color: #64748b; font-size: 1rem; margin-bottom: 2rem; line-height: 1.8;">
                Streamline your business operations. Track inventory in real-time, manage multiple suppliers,
                create professional invoices, and gain actionable insights into your revenue—all from one beautiful dashboard.
            </p>
            <div style="display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;">
                <a class="btn btn-primary btn-lg" asp-controller="Account" asp-action="Login">Sign In</a>
                <a class="btn btn-outline-primary btn-lg" asp-controller="Account" asp-action="Register">Create Account</a>
            </div>
            <p style="color: var(--muted); font-size: 0.9rem; margin-top: 1.5rem;">
                ✓ No credit card required • ✓ Free to start • ✓ Enterprise-ready
            </p>
        </div>
    </div>
</section>