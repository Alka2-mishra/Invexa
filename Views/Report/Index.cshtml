@model ReportViewModel
@{
    ViewData["Title"] = "Reports";
}

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="metric-card"><span>Today Revenue</span><h3>@Model.TodayRevenue.ToString("C")</h3></div></div>
    <div class="col-md-3"><div class="metric-card"><span>Monthly Revenue</span><h3>@Model.MonthlyRevenue.ToString("C")</h3></div></div>
    <div class="col-md-3"><div class="metric-card"><span>Total Invoices</span><h3>@Model.TotalInvoices</h3></div></div>
    <div class="col-md-3"><div class="metric-card"><span>Low Stock Items</span><h3>@Model.LowStockCount</h3></div></div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="panel">
            <h5>Low Stock Report</h5>
            <table class="table table-sm mt-3">
                <thead>
                    <tr><th>Product</th><th class="text-end">Qty</th></tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.LowStockProducts)
                    {
                        <tr><td>@item.Name</td><td class="text-end">@item.Quantity</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="panel">
            <h5>Recent Invoices</h5>
            <table class="table table-sm mt-3">
                <thead>
                    <tr><th>Date</th><th class="text-end">Amount</th></tr>
                </thead>
                <tbody>
                    @foreach (var invoice in Model.RecentInvoices)
                    {
                        <tr>
                            <td>@invoice.InvoiceDate.ToLocalTime().ToString("dd MMM yyyy")</td>
                            <td class="text-end">@invoice.TotalAmount.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>