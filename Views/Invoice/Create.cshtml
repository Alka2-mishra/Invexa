@model InvoiceViewModel
@{
    ViewData["Title"] = "Create Invoice";
}

<form asp-action="Create" method="post" class="row g-3">
    <div class="col-md-6">
        <label asp-for="CustomerName" class="form-label"></label>
        <input asp-for="CustomerName" class="form-control" placeholder="Customer name" />
    </div>
    <div class="col-md-3">
        <label asp-for="InvoiceDate" class="form-label"></label>
        <input asp-for="InvoiceDate" type="date" class="form-control" />
    </div>

    <div class="col-12">
        <h6>Line Items</h6>
        <div class="row g-2">
            @for (var i = 0; i < Model.Items.Count; i++)
            {
                <div class="col-md-8">
                    <select asp-for="Items[i].ProductId" asp-items="ViewBag.Products" class="form-select">
                        <option value="0">Select product</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <input asp-for="Items[i].Quantity" type="number" class="form-control" min="1" placeholder="Qty" />
                </div>
            }
        </div>
    </div>

    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Generate Invoice</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>