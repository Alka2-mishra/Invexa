@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-3 mb-4">
    <div class="col-md-3 col-sm-6">
        <div class="metric-card">
            <span>Total Products</span>
            <h3>@Model.TotalProducts</h3>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="metric-card">
            <span>Total Suppliers</span>
            <h3>@Model.TotalSuppliers</h3>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="metric-card">
            <span>Monthly Revenue</span>
            <h3>@Model.MonthlyRevenue.ToString("C")</h3>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="metric-card">
            <span>Today Revenue</span>
            <h3>@Model.TodayRevenue.ToString("C")</h3>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="panel">
            <h5 class="mb-3">Revenue Overview</h5>
            <canvas id="salesChart" height="120"></canvas>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="panel">
            <h5 class="mb-3">Low Stock Alerts</h5>
            @if (Model.LowStockProducts.Count == 0)
            {
                <p class="text-muted mb-0">No low stock products right now.</p>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @foreach (var item in Model.LowStockProducts)
                    {
                        <li class="list-group-item d-flex justify-content-between px-0">
                            <span>@item.Name</span>
                            <span class="badge text-bg-warning">@item.Quantity left</span>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-lg-6">
        <div class="panel">
            <h5 class="mb-3">Recent Products</h5>
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th class="text-end">Qty</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model.RecentProducts)
                    {
                        <tr>
                            <td>@product.Name</td>
                            <td class="text-end">@product.Quantity</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="panel">
            <h5 class="mb-3">Recent Invoices</h5>
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Customer</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var invoice in Model.RecentInvoices)
                    {
                        <tr>
                            <td>@invoice.InvoiceDate.ToLocalTime().ToString("dd MMM")</td>
                            <td>@(string.IsNullOrWhiteSpace(invoice.CustomerName) ? "Walk-in" : invoice.CustomerName)</td>
                            <td class="text-end">@invoice.TotalAmount.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        window.invexaChartData = {
            labels: ["Today", "Month", "Total"],
            values: [@Model.TodayRevenue.ToString(System.Globalization.CultureInfo.InvariantCulture), @Model.MonthlyRevenue.ToString(System.Globalization.CultureInfo.InvariantCulture), @Model.TotalRevenue.ToString(System.Globalization.CultureInfo.InvariantCulture)]
        };
    </script>
}@{
    var lowStock = ViewBag.LowStock as IEnumerable<Invexa.Models.Product>;
}

<h2>Dashboard</h2>

<div>
    <h4>Total Products: @ViewBag.TotalProducts</h4>
</div>

@if (lowStock != null && lowStock.Any())
{
    <div class="mt-3">
        <h5>Low Stock Alerts</h5>
        <ul>
            @foreach(var p in lowStock)
            {
                <li>@p.Name - @p.Quantity left</li>
            }
        </ul>
    </div>
}
