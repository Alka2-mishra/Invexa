<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Invexa</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @if ((ViewData["LandingPage"] as bool?) == true)
    {
        <main class="landing-main">
            @RenderBody()
        </main>
    }
    else
    {
    <div class="app-shell">
        <aside class="sidebar">
            <div class="brand">Invexa</div>
            <p class="brand-tag">Inventory and Billing</p>
            <nav class="nav flex-column mt-4 gap-1">
                <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                <a class="nav-link" asp-controller="Product" asp-action="Index">Products</a>
                <a class="nav-link" asp-controller="Category" asp-action="Index">Categories</a>
                <a class="nav-link" asp-controller="Supplier" asp-action="Index">Suppliers</a>
                <a class="nav-link" asp-controller="Invoice" asp-action="Index">Invoices</a>
                <a class="nav-link" asp-controller="Report" asp-action="Index">Reports</a>
            </nav>
            <hr />
            <div class="auth-links">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="small text-light d-block mb-2">@User.Identity.Name</span>
                    <form method="post" asp-controller="Account" asp-action="Logout" class="mt-2">
                        <button type="submit" class="btn btn-light btn-sm w-100">Logout</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-outline-light btn-sm w-100" asp-controller="Account" asp-action="Login">Login</a>
                    <a class="btn btn-light btn-sm w-100 mt-2" asp-controller="Account" asp-action="Register">Register</a>
                }
            </div>
        </aside>

        <main class="content-area">
            <div class="topbar">
                <h1 class="page-title">@ViewData["Title"]</h1>
            </div>
            <div class="content-card">
                @RenderBody()
            </div>
        </main>
    </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>